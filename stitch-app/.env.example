VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_API_BASE_URL=https://api.deepgram.com
DEEPGRAM_VOICE_MODEL=aura-2-thalia-en
DEEPGRAM_MAX_TEXT_CHARS=900
DEEPGRAM_TIMEOUT_MS=45000
VOICE_STREAM_SIGNING_SECRET=
VOICE_STREAM_TOKEN_TTL_MS=120000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-5.4-mini
OPENAI_PIPELINE_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=60000
BEDROCK_API_KEY=
BEDROCK_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com/openai/v1/
BEDROCK_MODEL=moonshotai.kimi-k2.5
BEDROCK_TIMEOUT_MS=60000
INCEPTION_API_KEY=
INCEPTION_BASE_URL=https://api.inceptionlabs.ai/v1
INCEPTION_MODEL=mercury-2
INCEPTION_TIMEOUT_MS=60000
INCEPTION_MAX_RETRIES=2
INCEPTION_RETRY_BASE_DELAY_MS=400
INCEPTION_RETRY_MAX_DELAY_MS=4000
VOYAGE_API_KEY=
VOYAGE_EMBEDDINGS_MODEL=voyage-large-2
VOYAGE_EMBEDDINGS_TIMEOUT_MS=20000
DATALAB_API_KEY=
DATALAB_API_BASE_URL=https://www.datalab.to
DATALAB_TIMEOUT_MS=240000
DATALAB_POLL_INTERVAL_MS=1500
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=
AZURE_DOCINTEL_API_VERSION=2023-07-31
DOCTRA_ENABLED=
DOCTRA_EXTRACT_URL=
DOCTRA_TIMEOUT_MS=120000
DOCTRA_SHARED_SECRET=
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_API_BASE_URL=https://api.cloud.llamaindex.ai
LLAMAPARSE_TIER=cost_effective
LLAMAPARSE_VERSION=latest
LLAMAPARSE_TIMEOUT_MS=180000
LLAMAPARSE_POLL_INTERVAL_MS=1500
TOPIC_ILLUSTRATION_GENERATION_ENABLED=false
TOPIC_PLACEHOLDER_ILLUSTRATION_URL=/topic-placeholder.svg

# Sentry (Frontend)
VITE_SENTRY_DSN=
VITE_SENTRY_TUNNEL=/api/sentry-tunnel
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# Sentry (Convex/Backend question-bank telemetry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_CAPTURE_TIMEOUT_MS=1500

# Convex (Frontend)
# Local dev may also use config/convex.public.json during `vite` serve.
# Preview/staging and production builds must set this explicitly.
VITE_CONVEX_URL=

# Better Auth (Convex backend)
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=
RESEND_API_KEY=

# PostHog (Frontend analytics + behavior monitoring)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_UI_HOST=https://us.posthog.com
VITE_POSTHOG_DEBUG=false

# Paystack upload top-up
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_FORWARD_SECRET=
PAYSTACK_TIMEOUT_MS=12000
# payment provider for top-up checkout: paystack or manual
PAYMENT_PROVIDER=paystack
APP_BASE_URL=http://localhost:5173
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Vercel webhook forwarder (serverless)
CONVEX_URL=

# Optional topic illustration image generation
GEMINI_API_KEY=

# OpenRouter Seedance 2.0 video generation (STAGING ONLY)
# Server-only (read by Convex actions). Do NOT prefix with VITE_ or this leaks
# into the client bundle. Set VIDEO_GEN_ENABLED=true on the staging Convex
# deployment only; leave unset in production.
OPENROUTER_VIDEO_API_KEY=
VIDEO_GEN_ENABLED=
MAX_CONCURRENT_VIDEO_JOBS=5
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Stitch (staging)
# Client-side feature flag. Staging build sets this to true; production leaves unset.
VITE_VIDEO_GEN_ENABLED=
