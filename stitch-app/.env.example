# Sentry (Frontend)
VITE_SENTRY_DSN=
VITE_SENTRY_TUNNEL=/api/sentry-tunnel
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# Sentry (Convex/Backend question-bank telemetry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_CAPTURE_TIMEOUT_MS=1500

# Convex (Frontend)
VITE_CONVEX_URL=

# PostHog (Frontend analytics + behavior monitoring)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_UI_HOST=https://us.posthog.com
VITE_POSTHOG_DEBUG=false

# ElevenLabs (lesson voice mode via Convex action)
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_MAX_TEXT_CHARS=2500

# Paystack upload top-up
PAYSTACK_SECRET_KEY=
