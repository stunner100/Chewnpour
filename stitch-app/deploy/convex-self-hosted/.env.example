ACME_EMAIL=ops@example.com
CONVEX_API_HOSTNAME=api.example.com
CONVEX_SITE_HOSTNAME=site.example.com
CONVEX_CLOUD_ORIGIN=https://api.example.com
CONVEX_SITE_ORIGIN=https://site.example.com
CONVEX_IMAGE_TAG=latest
INSTANCE_NAME=convex-self-hosted
DISABLE_BEACON=true
DISABLE_METRICS_ENDPOINT=true
RUST_LOG=info
# Cheapest starting point: leave SQLite in the Docker volume.
# For managed Postgres later, set POSTGRES_URL without a database name.
POSTGRES_URL=
MYSQL_URL=
DO_NOT_REQUIRE_SSL=
